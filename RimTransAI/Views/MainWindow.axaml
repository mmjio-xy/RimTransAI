<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RimTransAI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:iconMaterial="clr-namespace:IconPacks.Avalonia.Material;assembly=IconPacks.Avalonia.Material"
        mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="700"
        x:Class="RimTransAI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="RimTrans AI - 边缘世界智能汉化"
        Width="1400"
        Height="700"
        ExtendClientAreaToDecorationsHint="True"
        Icon="avares://RimTransAI/Assets/RimTrans.ico"
        SystemDecorations="Full"
        Background="{DynamicResource SemiColorBackground0}">

    <Grid RowDefinitions="30,*,Auto">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="12,4,12,0">
            <TextBlock Grid.Column="0"
                       Text="{Binding AppDisplayTitle}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource SemiColorText2}"/>
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8"
                        HorizontalAlignment="Right"
                        Margin="0,0,140,0">
                <Button Command="{Binding OpenSettingsCommand}"
                        Theme="{x:Null}"
                        Width="20"
                        Height="20"
                        Padding="0"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        ToolTip.Tip="程序设置">
                    <iconMaterial:PackIconMaterial Kind="CogOutline"
                                                   Width="16"
                                                   Height="16"
                                                   Foreground="{DynamicResource SemiColorText2}"/>
                </Button>
                <Button Command="{Binding OpenBackupManagerCommand}"
                        Theme="{x:Null}"
                        Width="20"
                        Height="20"
                        Padding="0"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        ToolTip.Tip="备份管理">
                    <iconMaterial:PackIconMaterial Kind="ArchiveOutline"
                                                   Width="16"
                                                   Height="16"
                                                   Foreground="{DynamicResource SemiColorText2}"/>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="27*,26*,47*" Margin="12,8,12,8">

            <!-- 左栏：Mod 信息 -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SemiColorBackground0}"
                    BorderBrush="{DynamicResource SemiColorBorder}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,10,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <iconMaterial:PackIconMaterial Kind="InformationOutline"
                                                           Width="18"
                                                           Height="18"
                                                           Foreground="{DynamicResource SemiColorText1}"/>
                            <TextBlock Text="Mod 信息" Classes="H5" Theme="{DynamicResource TitleTextBlock}"/>
                        </StackPanel>

                        <Border CornerRadius="8" Background="{DynamicResource SemiColorFill0}" Padding="8" ClipToBounds="True">
                            <Image Source="{Binding ModInfoViewModel.PreviewImage}" Height="170" Stretch="UniformToFill"/>
                        </Border>

                        <TextBlock Text="{Binding ModInfoViewModel.Name}" FontSize="18" FontWeight="Bold" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding ModInfoViewModel.Author, StringFormat='作者: {0}'}"
                                   Foreground="{DynamicResource SemiColorText2}"
                                   TextWrapping="Wrap"/>
                        <StackPanel Spacing="2">
                            <TextBlock Text="简介:" FontSize="12" Foreground="{DynamicResource SemiColorText3}"/>
                            <TextBlock x:Name="ModDescriptionTextBlock"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SemiColorText2}"/>
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="包ID:" FontSize="12" Foreground="{DynamicResource SemiColorText3}"/>
                            <TextBlock Text="{Binding ModInfoViewModel.PackageId}"
                                       FontFamily="Consolas,Courier New"
                                       Foreground="{DynamicResource SemiColorText2}"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip.Tip="{Binding ModInfoViewModel.PackageId}"/>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Mod目录:" FontSize="12" Foreground="{DynamicResource SemiColorText3}"/>
                            <Button Command="{Binding ModInfoViewModel.OpenFolderCommand}"
                                    Theme="{x:Null}"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    ToolTip.Tip="点击打开目录">
                                <TextBlock Text="{Binding ModInfoViewModel.FolderPath}"
                                           Foreground="#2E6E9E"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip.Tip="{Binding ModInfoViewModel.FolderPath}"/>
                            </Button>

                            <TextBlock Text="项目主页:" FontSize="12" Foreground="{DynamicResource SemiColorText3}"/>
                            <Button Command="{Binding ModInfoViewModel.OpenUrlCommand}"
                                    Theme="{x:Null}"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    IsVisible="{Binding ModInfoViewModel.HasUrl}">
                                <ToolTip.Tip>
                                    <Border MaxWidth="760" Padding="4">
                                        <TextBlock Text="{Binding ModInfoViewModel.ResolvedUrl}"
                                                   TextWrapping="Wrap"/>
                                    </Border>
                                </ToolTip.Tip>
                                <TextBlock Text="{Binding ModInfoViewModel.ResolvedUrl}"
                                           Foreground="#2E6E9E"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"/>
                            </Button>
                            <TextBlock Text="(无项目主页)"
                                       Foreground="{DynamicResource SemiColorText3}"
                                       IsVisible="{Binding !ModInfoViewModel.HasUrl}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 中栏：Mod 列表 -->
            <Border Grid.Column="1"
                    Background="{DynamicResource SemiColorBackground0}"
                    BorderBrush="{DynamicResource SemiColorBorder}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,10,0">
                <Grid RowDefinitions="Auto,Auto,*">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <iconMaterial:PackIconMaterial Kind="ViewList" Width="18" Height="18" Foreground="{DynamicResource SemiColorText1}"/>
                            <TextBlock Text="Mod 列表" Classes="H5" Theme="{DynamicResource TitleTextBlock}"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Command="{Binding RefreshWorkspaceCommand}"
                                Theme="{x:Null}"
                                Width="20"
                                Height="20"
                                Padding="0"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                ToolTip.Tip="刷新来源">
                            <iconMaterial:PackIconMaterial Kind="Refresh" Width="16" Height="16" Foreground="{DynamicResource SemiColorText2}"/>
                        </Button>
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="Auto,*" Margin="0,10,0,10">
                        <ComboBox Grid.Column="0" Width="110" SelectedIndex="{Binding ModSearchModeIndex}">
                            <ComboBoxItem>按Mod名称</ComboBoxItem>
                            <ComboBoxItem>按包名</ComboBoxItem>
                        </ComboBox>
                        <TextBox Grid.Column="1"
                                 Text="{Binding ModSearchText}"
                                 Watermark="输入关键词搜索"
                                 Margin="8,0,0,0"
                                 HorizontalAlignment="Stretch"/>
                    </Grid>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding WorkspaceMods}"
                             SelectedItem="{Binding SelectedMod}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8" Margin="0,0,0,6" BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="1" CornerRadius="6">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <iconMaterial:PackIconMaterial Grid.Column="0"
                                                                       Kind="{Binding SourceIconKind}"
                                                                       Width="18"
                                                                       Height="18"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource SemiColorPrimary}"/>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding SourceDisplayName}" FontSize="11" Foreground="{DynamicResource SemiColorText3}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding PackageId}" FontSize="11" Foreground="{DynamicResource SemiColorText2}" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Spacing="2" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Status}" FontSize="11" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding ItemCount, StringFormat='条目: {0}'}" FontSize="10" Foreground="{DynamicResource SemiColorText3}" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 右栏：摘要 + 键值表格 -->
            <Border Grid.Column="2"
                    Background="{DynamicResource SemiColorBackground0}"
                    BorderBrush="{DynamicResource SemiColorBorder}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">
                <Grid RowDefinitions="Auto,Auto,*">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,10,0" ClipToBounds="True">
                            <TextBlock Text="{Binding CurrentModDisplayName}"
                                       Classes="H5"
                                       Theme="{DynamicResource TitleTextBlock}"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding CurrentDataState}" FontSize="12" Foreground="{DynamicResource SemiColorText3}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <Grid Grid.Column="1" ColumnDefinitions="Auto,5,Auto">
                            <Button Grid.Column="0" Width="128" Command="{Binding StartTranslationCommand}" IsVisible="{Binding !IsTranslating}" Theme="{DynamicResource SolidButton}" Classes="Success">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <iconMaterial:PackIconMaterial Kind="Play" Width="16" Height="16"/>
                                    <TextBlock Text="开始翻译"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="0" Width="128" Command="{Binding StopTranslationCommand}" IsVisible="{Binding IsTranslating}" Theme="{DynamicResource SolidButton}" Classes="Danger">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <iconMaterial:PackIconMaterial Kind="Stop" Width="16" Height="16"/>
                                    <TextBlock Text="停止翻译"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="2" Width="128" Command="{Binding SaveFilesCommand}" Theme="{DynamicResource SolidButton}" Classes="Warning">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <iconMaterial:PackIconMaterial Kind="ContentSave" Width="16" Height="16"/>
                                    <TextBlock Text="保存"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Grid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="0,10,0,10">
                        <Button Command="{Binding LoadOrRefreshTranslationItemsCommand}" Theme="{DynamicResource SolidButton}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <iconMaterial:PackIconMaterial Kind="Download" Width="16" Height="16" IsVisible="{Binding !HasSelectedModCache}"/>
                                <iconMaterial:PackIconMaterial Kind="Refresh" Width="16" Height="16" IsVisible="{Binding HasSelectedModCache}"/>
                                <TextBlock Text="{Binding LoadOrRefreshTranslationText}"/>
                            </StackPanel>
                        </Button>
                        <TextBlock Text="版本过滤" VerticalAlignment="Center"/>
                        <ComboBox Width="180"
                                  ItemsSource="{Binding AvailableVersions}"
                                  SelectedItem="{Binding SelectedVersion}"
                                  PlaceholderText="全部" />
                        <ProgressBar Width="220" Minimum="0" Maximum="100" Value="{Binding ProgressValue}" IsVisible="{Binding IsTranslating}"/>
                    </StackPanel>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding TranslationItems}"
                              IsReadOnly="{Binding IsTranslationTableReadOnly}"
                              CanUserResizeColumns="True"
                              GridLinesVisibility="All"
                              BorderThickness="1"
                              BorderBrush="{DynamicResource SemiColorBorder}"
                              Background="{DynamicResource SemiColorBackground0}"
                              CellEditEnding="OnCellEditEnding">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="版本" Binding="{Binding Version}" Width="90" IsReadOnly="True" />
                            <DataGridTextColumn Header="Key" Binding="{Binding Key}" Width="220" IsReadOnly="True" />
                            <DataGridTextColumn Header="原文" Binding="{Binding OriginalText}" Width="3*" IsReadOnly="True" />
                            <DataGridTextColumn Header="译文" Binding="{Binding TranslatedText, Mode=TwoWay}" Width="3*" IsReadOnly="False" />
                            <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="100" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Expander Grid.Row="2"
                  IsExpanded="False"
                  Margin="12,0,12,10"
                  HorizontalContentAlignment="Stretch">
            <Expander.Header>
                <Grid ColumnDefinitions="Auto,*" MinWidth="420">
                    <TextBlock Text="运行日志" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding LatestLogLine}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SemiColorText3}"
                               TextTrimming="CharacterEllipsis"/>
                </Grid>
            </Expander.Header>
            <Border Background="{DynamicResource SemiColorFill0}"
                    BorderBrush="{DynamicResource SemiColorBorder}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10">
                <ScrollViewer Height="130" VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding LogOutput}" TextWrapping="Wrap" Foreground="{DynamicResource SemiColorText2}" FontSize="12"/>
                </ScrollViewer>
            </Border>
        </Expander>
    </Grid>
</Window>
