<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:RimTransAI.ViewModels"
        xmlns:iconMaterial="clr-namespace:IconPacks.Avalonia.Material;assembly=IconPacks.Avalonia.Material"
        mc:Ignorable="d"
        d:DesignWidth="520"
        d:DesignHeight="380"
        x:Class="RimTransAI.Views.ModSourceEditorWindow"
        x:DataType="vm:ModSourceEditorViewModel"
        Title="{Binding DialogTitle}"
        Width="520"
        Height="380"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        SystemDecorations="Full"
        Background="{DynamicResource SemiColorBackground0}">

    <Grid RowDefinitions="Auto,*,Auto" Margin="0,30,0,0">
        <TextBlock Grid.Row="0"
                   Text="{Binding DialogTitle}"
                   Classes="H4"
                   Theme="{DynamicResource TitleTextBlock}"
                   Margin="25,15,25,10"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="25,0,25,0">
            <StackPanel Spacing="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="显示名称" Classes="Tertiary"/>
                    <TextBox Text="{Binding DisplayName}" Watermark="例如：Steam 创意工坊"/>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="来源目录路径" Classes="Tertiary"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0"
                                 Text="{Binding FolderPath}"
                                 IsReadOnly="True"
                                 Margin="0,0,10,0"/>
                        <Button Grid.Column="1"
                                Content="浏览..."
                                Command="{Binding BrowseFolderCommand}"
                                Theme="{DynamicResource OutlineButton}"/>
                    </Grid>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="来源图标 (IconPacks Material)" Classes="Tertiary"/>
                    <ComboBox ItemsSource="{Binding IconOptions}"
                              SelectedItem="{Binding SelectedIconOption}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <iconMaterial:PackIconMaterial Kind="{Binding Kind}"
                                                                   Width="16"
                                                                   Height="16"
                                                                   VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="状态" Classes="Tertiary"/>
                    <ToggleSwitch IsChecked="{Binding IsEnabled}" OnContent="启用" OffContent="禁用"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="25,15,25,20">
            <StackPanel>
                <TextBlock Text="{Binding ValidationError}"
                           Foreground="#E53935"
                           FontSize="13"
                           Margin="0,0,0,10"
                           TextWrapping="Wrap"
                           IsVisible="{Binding HasValidationError}"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                    <Button Content="取消"
                            Command="{Binding CancelCommand}"
                            Theme="{DynamicResource TertiaryButton}"
                            Width="90"/>
                    <Button Content="保存"
                            Command="{Binding SaveCommand}"
                            Theme="{DynamicResource SolidButton}"
                            Classes="Primary"
                            Width="90"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
