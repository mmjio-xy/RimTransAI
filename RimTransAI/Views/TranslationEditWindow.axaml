<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="420"
        x:Class="RimTransAI.Views.TranslationEditWindow"
        Title="编辑译文"
        Width="500"
        Height="420"
        MinWidth="400"
        MinHeight="300"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        WindowDecorations="Full"
        Background="{DynamicResource SemiColorBackground0}">

    <Grid RowDefinitions="Auto,*,Auto" Margin="0">

        <!-- ========== 标题栏 ========== -->
        <TextBlock Grid.Row="0"
                   Text="编辑译文"
                   Classes="H4"
                   Theme="{DynamicResource TitleTextBlock}"
                   Margin="25,15,25,10"/>

        <!-- ========== 内容区 ========== -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="25,0,25,0">
            <StackPanel Spacing="12">

                <!-- Key -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Key" Classes="Tertiary" FontSize="12"/>
                    <Border Background="{DynamicResource SemiColorFill0}"
                            BorderBrush="{DynamicResource SemiColorBorder}"
                            BorderThickness="1" CornerRadius="4" Padding="10,6">
                        <TextBlock x:Name="KeyTextBlock"
                                   TextWrapping="Wrap"
                                   FontSize="13"/>
                    </Border>
                </StackPanel>

                <!-- 原文 -->
                <StackPanel Spacing="4">
                    <TextBlock Text="原文" Classes="Tertiary" FontSize="12"/>
                    <Border Background="{DynamicResource SemiColorFill0}"
                            BorderBrush="{DynamicResource SemiColorBorder}"
                            BorderThickness="1" CornerRadius="4" Padding="10,6">
                        <ScrollViewer MaxHeight="120" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="OriginalTextBlock"
                                       TextWrapping="Wrap"
                                       FontSize="13"/>
                        </ScrollViewer>
                    </Border>
                </StackPanel>

                <!-- 编辑区 -->
                <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="译文" Classes="Tertiary" FontSize="12"/>
                        <materialIcons:MaterialIcon Kind="Pencil"
                                                       Width="14" Height="14"
                                                       Foreground="{DynamicResource SemiColorText3}"
                                                       VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border BorderBrush="{DynamicResource SemiColorPrimary}"
                            BorderThickness="1.5" CornerRadius="4">
                        <TextBox x:Name="TranslationTextBox"
                                 MinHeight="80"
                                 MaxHeight="200"
                                 Padding="10,6"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 FontSize="13"
                                 Background="{DynamicResource SemiColorBackground0}"/>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- ========== 底部按钮 ========== -->
        <Border Grid.Row="2" Padding="25,15,25,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="15">
                <Button x:Name="CancelButton"
                        Content="取消"
                        Theme="{DynamicResource TertiaryButton}"
                        Width="90"/>
                <Button x:Name="ConfirmButton"
                        Theme="{DynamicResource SolidButton}"
                        Classes="Success"
                        Width="90">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <materialIcons:MaterialIcon Kind="Check"
                                                       Width="16" Height="16"
                                                       IsHitTestVisible="False"/>
                        <TextBlock Text="确认"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

    </Grid>
</Window>
